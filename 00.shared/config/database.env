# Database Configuration for tdx2db_rust
# 策略仓库数据库连接配置
#
# 注意: tdx2db-rust 表结构适配
# 在 ClickHouse 中运行: 00.shared/sql/tdx2db_rust_adapter.sql
# 创建兼容性视图以适配不同版本的 tdx2db-rust schema
#
# 适配内容:
#   - v_stock_sectors: 兼容 sector_code 字段名
#   - v_stock_industry_mapping: 行业映射视图
#   - v_gtja_stock_names: 股票名称视图
#   - v_gtja_industry_list: 行业列表视图
#   - v_raw_index_daily: 指数数据视图

# ClickHouse 配置 (tdx2db_rust)
export CH_HOST=localhost
export CH_PORT=9000
export CH_DB=tdx2db_rust
export CH_USER=default
export CH_PASSWORD=tdx2db

# PostgreSQL 配置 (quantdb)
export PG_HOST=localhost
export PG_PORT=5432
export PG_DB=quantdb
export PG_USER=postgres
export PG_PASSWORD=postgres
